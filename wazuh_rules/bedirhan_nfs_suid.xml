<group name="custom_nfs_suid_hardening,">
  <rule id="110201" level="10">
    <if_sid>550</if_sid>
    <field name="file">/etc/exports</field>
    <description>Kritik: NFS yapilandirma dosyasi (/etc/exports) degistirildi!</description>
    <mitre><id>T1068</id></mitre>
  </rule>
  <rule id="110202" level="12">
    <if_sid>5400</if_sid>
    <match>find</match>
    <description>Tehdit: 'find' komutu sudo ile calistirildi (Olasi SUID istismari!)</description>
    <mitre><id>T1548.001</id></mitre>
  </rule>
</group>