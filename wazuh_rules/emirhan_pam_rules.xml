<group name="linux,pam_hardening,privilege_escalation,backdoor,">
  <rule id="110301" level="12">
    <if_sid>550</if_sid>
    <field name="file">/etc/pam.d/common-auth|/etc/pam.d/sudo</field>
    <description>Kritik: PAM kimlik dogrulama dosyasi degistirildi! Olasi backdoor girisimi.</description>
    <mitre><id>T1556.003</id></mitre>
  </rule>
  <rule id="110302" level="12">
    <if_sid>550</if_sid>
    <field name="file">/usr/local/bin/pam_backdoor.sh</field>
    <description>SOC ALARMI: PAM backdoor scripti olusturuldu veya degistirildi!</description>
    <mitre><id>T1059.004</id></mitre>
  </rule>
  <rule id="110303" level="10">
    <if_sid>5902</if_sid>
    <match>backdooruser</match>
    <description>Uyari: Zafiyet testi icin 'backdooruser' kullanicisi acildi!</description>
    <mitre><id>T1136.001</id></mitre>
  </rule>
</group>